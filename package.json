{
  "name": "contract-ops-agent",
  "version": "0.3.0",
  "description": "Contract work in an enclosure: a Claude Agent SDK agent whose only tools are the contract-ops suite — no shell, no filesystem, no signing.",
  "type": "module",
  "scripts": {
    "spike": "node spike.mjs",
    "test": "node --test test/unit.mjs test/onboarding.mjs",
    "test:live": "node --test --test-concurrency=1 test/live.mjs",
    "test:live:openai": "node --test --test-concurrency=1 test/live-openai.mjs",
    "test:loop": "node --test test/loop.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "contract-ops-mcp": "^0.1.7",
    "openai": "^6.46.0"
  },
  "bin": {
    "contract-ops-agent": "./bin/contract-ops-agent.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DrBaher/contract-ops-agent.git"
  }
}
